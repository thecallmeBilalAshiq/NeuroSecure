{
  "name": "neurosecure-backend",
  "version": "1.0.0",
  "private": true,
  "description": "NeuroSecure backend API",
  "main": "dist/main.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/main.ts",
    "build": "prisma generate && rimraf dist && tsc -p tsconfig.json",
    "vercel-build": "npx prisma generate && npm run build",
    "start": "prisma migrate deploy && cross-env NODE_ENV=production node dist/main.js",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:push": "prisma db push --skip-generate",
    "prisma:studio": "prisma studio",
    "user:delete": "tsx scripts/delete-user.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.13",
    "zod": "^3.23.8",
    "prisma": "^5.22.0",
    "typescript": "~5.6.3",
    "rimraf": "^6.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^7.0.11",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2"
  }
}
