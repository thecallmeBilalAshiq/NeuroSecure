{
  "name": "neurosecure-extension",
  "version": "1.0.0",
  "private": true,
  "displayName": "NeuroSecure",
  "description": "AI-powered browser privacy protection",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "postdev": "node scripts/copy-public.js",
    "postbuild": "node scripts/copy-public.js",
    "copy:public": "node scripts/copy-public.js",
    "package": "plasmo package",
    "clean": "rimraf build .plasmo"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "face-api.js": "^0.22.2",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.281",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  },
  "manifest": {
    "name": "NeuroSecure",
    "version": "1.0.0",
    "description": "AI-powered browser privacy protection",
    "permissions": [
      "storage",
      "activeTab",
      "tabs",
      "notifications",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "models/*"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
  }
}
